      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
        http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

    <munit:config name="weather-api-test-suite"/>

    <munit:test name="weather-experience-flow-happy-path-test" description="Happy path">
        <munit:behavior>
            <munit-tools:mock-when doc:name="Mock GET Open-Meteo Forecast" processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="GET Open-Meteo Forecast"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[MunitTools::getResourceAsString('weatherexperienceFlowtest/mock_get-open-meteo-forecast_1_1.dwl')]" mediaType="application/json"/>
                    <munit-tools:attributes value="#[read(MunitTools::getResourceAsString('weatherexperienceFlowtest/mock_get-open-meteo-forecast_1_1_attributes.dwl'), 'application/json')]" mediaType="application/java"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
            <munit-tools:spy doc:name="Spy Extract Request Variables" processor="ee:transform">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Extract Request Variables"/>
                </munit-tools:with-attributes>
                <munit-tools:after-call>
                    <munit-tools:assert-that
                        doc:name="Assert Extract Request Variables output"
                        expression="#[payload]"
                        is="#[MunitTools::notNullValue()]"
                        message="DataWeave output should be present"/>
                </munit-tools:after-call>
            </munit-tools:spy>
            <munit-tools:spy doc:name="Spy Parse API Response" processor="ee:transform">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Parse API Response"/>
                </munit-tools:with-attributes>
                <munit-tools:after-call>
                    <munit-tools:assert-that
                        doc:name="Assert Parse API Response output"
                        expression="#[payload]"
                        is="#[MunitTools::notNullValue()]"
                        message="DataWeave output should be present"/>
                </munit-tools:after-call>
            </munit-tools:spy>
            <munit-tools:spy doc:name="Spy Transform to Business Object" processor="ee:transform">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Transform to Business Object"/>
                </munit-tools:with-attributes>
                <munit-tools:after-call>
                    <munit-tools:assert-that
                        doc:name="Assert Transform to Business Object output"
                        expression="#[payload]"
                        is="#[MunitTools::notNullValue()]"
                        message="DataWeave output should be present"/>
                </munit-tools:after-call>
            </munit-tools:spy>
            <munit-tools:spy doc:name="Spy Build Final API Response" processor="ee:transform">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Build Final API Response"/>
                </munit-tools:with-attributes>
                <munit-tools:after-call>
                    <munit-tools:assert-that
                        doc:name="Assert Build Final API Response output"
                        expression="#[payload]"
                        is="#[MunitTools::notNullValue()]"
                        message="DataWeave output should be present"/>
                </munit-tools:after-call>
            </munit-tools:spy>
        </munit:behavior>
        <munit:execution>
            <munit:set-event doc:name="Set Input">
                <munit:payload value="#[MunitTools::getResourceAsString('weatherexperienceFlowtest/set-event_payload_2.dwl')]" encoding="UTF-8" mediaType="application/json" />
				<munit:attributes value="#[read(MunitTools::getResourceAsString('weatherexperienceFlowtest/set-event_attributes_1.dwl'), 'application/json')]" mediaType="application/java" />
            </munit:set-event>
            <flow-ref doc:name="Execute weather-experience-flow" name="weather-experience-flow"/>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert doc:name="Assert payload" message="The payload does not match expected response">
                <munit-tools:that><![CDATA[#[%dw 2.0
import weatherexperienceFlowtest::assert_expression_payload_1
---
weatherexperienceFlowtest::assert_expression_payload_1::main({payload: payload, attributes: attributes, vars: vars})]]]></munit-tools:that>
            </munit-tools:assert>
        </munit:validation>
    </munit:test>
    <munit:test name="weather-experience-flow-branch-1-raises-error-test" description="when branch 1: #[payload.latitude == null or payload.longitude == null]" expectedErrorType="APP:VALIDATION_ERROR">
        <munit:behavior>

        </munit:behavior>
        <munit:execution>
            <munit:set-event doc:name="Set Input">
                <munit:payload value="#[MunitTools::getResourceAsString('weatherexperienceFlowtest/set-event_payload_1.dwl')]" mediaType="application/json" encoding="UTF-8"/>
                <munit:attributes value="#[read(MunitTools::getResourceAsString('weatherexperienceFlowtest/set-event_attributes_1.dwl'), 'application/json')]" mediaType="application/java"/>
            </munit:set-event>
            <flow-ref doc:name="Execute weather-experience-flow" name="weather-experience-flow"/>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that
                doc:name="Assert error type"
                expression="#[error.errorType.identifier]"
                is="#[MunitTools::equalTo('VALIDATION_ERROR')]"
                message="invalid input should trigger validation error"/>
            <munit-tools:verify-call doc:name="Verify Log Connectivity Error" processor="logger" times="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Log Connectivity Error"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
            <munit-tools:verify-call doc:name="Verify Log Unexpected Error" processor="logger" times="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="Log Unexpected Error"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>
    <munit:test name="weather-experience-flow-branch-2-raises-error-test" description="when branch 2: #[payload.latitude &lt; -90.0 or payload.latitude &gt; 90.0]" expectedErrorType="APP:VALIDATION_ERROR">
        <munit:behavior>

        </munit:behavior>
        <munit:execution>
